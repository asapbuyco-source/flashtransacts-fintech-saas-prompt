VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

EMAIL_PROVIDER=resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=notify@yourdomain.com
RESEND_FROM_DOMAIN=
RESEND_REPLY_TO=

# Gmail SMTP option. Set EMAIL_PROVIDER=gmail_smtp to use this path.
GMAIL_USER=
GMAIL_FROM_EMAIL=
GMAIL_FROM_NAME=FlashTransacts
GMAIL_FROM_NAME_MODE=template
GMAIL_APP_PASSWORD=
GMAIL_REPLY_TO=

# Optional Google Console OAuth2 option for Gmail SMTP.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_SMTP_HOST=smtp.gmail.com
GMAIL_SMTP_PORT=465
GMAIL_SMTP_SECURE=true
